# Copiar para `.env` e preencher com os dados do projeto Supabase.
# A chave PUBLISHABLE é feita para o cliente (protegida por Row Level Security).
# NUNCA colocar aqui a chave "secret"/service_role.
EXPO_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# `dev` põe uma faixa roxa no topo da app a dizer que os dados não são reais.
# Deixar assim em qualquer máquina de desenvolvimento — só produção é que não
# tem esta linha. Ver AMBIENTES.md.
EXPO_PUBLIC_AMBIENTE=dev
